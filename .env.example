# Dify Workflow（run_eval.py）
DIFY_API_URL=https://your-dify-host/v1/workflows/run
DIFY_API_KEY=app-your-dify-app-key

# LLM（analyze_reports.py / car_dialogue_generator.py）
LLM_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=sk-your-api-key
LLM_MODEL_NAME=qwen3.5-plus

# 可选：覆盖默认 sample 数据路径（相对项目根目录或绝对路径）
# QUERY_FILE=data/input/car_dialogue_dataset_500_高质量.json
# CASES_FILE=data/input/china_cases_500.txt
# ALL_CASE_JSON=data/input/car_dialogue_dataset_500_高质量.json

